{
  "name": "codereader",
  "publisher": "zachflower",
  "displayName": "CodeReader",
  "description": "Read EPUBs disguised as code",
  "version": "0.1.3",
  "repository": {
    "type": "git",
    "url": "https://github.com/zachflower/codereader.git"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "icon": "logo.png",
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codereader.openEpub",
        "title": "CodeReader: Open EPUB"
      },
      {
        "command": "codereader.switchLanguage",
        "title": "CodeReader: Switch Language"
      },
      {
        "command": "codereader.removeHighlight",
        "title": "CodeReader: Remove Highlight"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "codereader.removeHighlight",
          "when": "resourceScheme == codereader",
          "group": "codereader@1"
        }
      ],
      "commandPalette": [
        {
          "command": "codereader.switchLanguage",
          "when": "codereader.isActive"
        },
        {
          "command": "codereader.removeHighlight",
          "when": "codereader.isActive"
        }
      ]
    },
    "configuration": {
      "title": "CodeReader",
      "properties": {
        "codereader.language": {
          "type": "string",
          "enum": ["python", "javascript", "php", "go", "c", "cpp", "rust", "ruby", "csharp", "vb", "typescript", "objectivec", "java", "swift", "shellscript", "bat", "powershell", "clojure"],
          "enumDescriptions": [
            "Render books as Python code",
            "Render books as JavaScript code",
            "Render books as PHP code",
            "Render books as Go code",
            "Render books as C code",
            "Render books as C++ code",
            "Render books as Rust code",
            "Render books as Ruby code",
            "Render books as C# code",
            "Render books as Visual Basic code",
            "Render books as TypeScript code",
            "Render books as Objective-C code",
            "Render books as Java code",
            "Render books as Swift code",
            "Render books as Bash code",
            "Render books as Batch code",
            "Render books as PowerShell code",
            "Render books as Clojure code"
          ],
          "default": "python",
          "description": "Programming language used to render EPUBs"
        },
        "codereader.wordWrap": {
          "type": "boolean",
          "default": true,
          "description": "Automatically enable word wrap when opening EPUBs in CodeReader"
        }
      }
    },
    "customEditors": [
      {
        "viewType": "codereader.epubEditor",
        "displayName": "CodeReader EPUB Editor",
        "selector": [
          {
            "filenamePattern": "*.epub"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/mocha": "^10.0.10",
    "@types/node": ">=20.x",
    "@types/vscode": "^1.96.0",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^8.17.0",
    "@typescript-eslint/parser": "^8.17.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "esbuild": "^0.24.0",
    "eslint": "^9.16.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "adm-zip": "^0.5.10",
    "xml2js": "^0.6.2"
  }
}
